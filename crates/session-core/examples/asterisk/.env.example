# Remote Asterisk SIP server (defaults match the rvoip dev lab).
SIP_SERVER=192.168.1.103
SIP_PORT=5060
SIP_TRANSPORT=UDP

# Single-endpoint registration smoke test defaults.
SIP_USERNAME=1001
SIP_AUTH_USERNAME=1001

# Two-endpoint audio path test. Both endpoints use SIP_PASSWORD unless
# endpoint-specific auth usernames are overridden here.
ENDPOINT_1001_AUTH_USERNAME=1001
ENDPOINT_1002_AUTH_USERNAME=1002
SIP_PASSWORD=password123

# Local bind. If LOCAL_IP is 0.0.0.0, ADVERTISED_IP must be set so
# REGISTER Contact does not advertise an unspecified address.
LOCAL_IP=0.0.0.0
ADVERTISED_IP=192.168.1.3

# Single-endpoint registration smoke test port.
LOCAL_PORT=5070

# Two-endpoint SIP and RTP ports. Keep ranges non-overlapping.
ENDPOINT_1001_LOCAL_PORT=5070
ENDPOINT_1002_LOCAL_PORT=5072
ENDPOINT_1001_MEDIA_PORT_START=16000
ENDPOINT_1001_MEDIA_PORT_END=16100
ENDPOINT_1002_MEDIA_PORT_START=16120
ENDPOINT_1002_MEDIA_PORT_END=16220

# Optional override when the Asterisk dialplan expects a different URI.
# Default is sip:1002@${SIP_SERVER} or sip:1002@${SIP_SERVER}:${SIP_PORT}.
# ENDPOINT_1001_CALL_URI=sip:1002@192.168.1.103:5060

# Let both registered contacts sit briefly so Asterisk qualify OPTIONS probes
# can run before endpoint 1001 places the test call.
POST_REGISTER_SETTLE_SECS=5

# Asterisk audio-path output.
AUDIO_OUTPUT_DIR=examples/asterisk/output

# How long to hold the registration before unregistering and exiting.
IDLE_SECS=30
