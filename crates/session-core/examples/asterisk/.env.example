# Remote Asterisk SIP server (defaults match the rvoip dev lab).
SIP_SERVER=192.168.1.103
SIP_PORT=5060
SIP_TRANSPORT=TLS

# Shared credentials. The lab Asterisk users 1001/1002 (TLS/SRTP) and
# 2001/2002 (UDP) all use this password unless auth usernames are overridden.
SIP_PASSWORD=password123

# Single-endpoint registration smoke test defaults to secure user 1001.
SIP_USERNAME=1001
SIP_AUTH_USERNAME=1001

# TLS registration and TLS/SRTP call examples.
SIP_TLS_PORT=5061
TLS_CA_PATH=/path/to/asterisk-ca.pem
TLS_INSECURE=0
ASTERISK_TLS_SRTP_REQUIRED=1

# Optional mutual TLS client credentials. Leave unset for the normal
# Asterisk client/B2BUA flow where Asterisk presents the server cert and
# the RVOIP endpoint only verifies it.
# TLS_CLIENT_CERT_PATH=/path/to/client.pem
# TLS_CLIENT_KEY_PATH=/path/to/client-key.pem

# Optional direct-UAS/listener TLS credentials for applications that accept
# new inbound TLS connections directly. The Asterisk examples do not require
# these because 1001/1002 register outbound to Asterisk over TLS.
# TLS_CERT_PATH=/path/to/listener.pem
# TLS_KEY_PATH=/path/to/listener-key.pem

# Local bind. If LOCAL_IP is 0.0.0.0, ADVERTISED_IP must be set so
# REGISTER Contact does not advertise an unspecified address.
LOCAL_IP=0.0.0.0
ADVERTISED_IP=192.168.1.3

# Single-endpoint registration smoke test SIP port.
LOCAL_PORT=5070

# Secure TLS/SRTP users. The Asterisk examples use TLS client-only mode, so
# Contact advertises the logical local SIP port and calls arrive on the
# registered TLS flow.
ENDPOINT_1001_LOCAL_PORT=5070
ENDPOINT_1002_LOCAL_PORT=5072
ENDPOINT_1001_MEDIA_PORT_START=16000
ENDPOINT_1001_MEDIA_PORT_END=16100
ENDPOINT_1002_MEDIA_PORT_START=16120
ENDPOINT_1002_MEDIA_PORT_END=16220

# UDP/plain RTP users. The UDP scripts force SIP_TRANSPORT=UDP.
ENDPOINT_2001_LOCAL_PORT=5080
ENDPOINT_2002_LOCAL_PORT=5082
ENDPOINT_2001_MEDIA_PORT_START=17000
ENDPOINT_2001_MEDIA_PORT_END=17100
ENDPOINT_2002_MEDIA_PORT_START=17120
ENDPOINT_2002_MEDIA_PORT_END=17220

# Optional overrides when the Asterisk dialplan expects a different URI.
# ENDPOINT_1001_CALL_URI=sips:1002@192.168.1.103:5061
# ENDPOINT_2001_CALL_URI=sip:2002@192.168.1.103:5060

# Let both registered contacts sit briefly so Asterisk qualify OPTIONS probes
# can run before the caller places the test call.
POST_REGISTER_SETTLE_SECS=5

# Asterisk audio-path output when running endpoint binaries directly.
# The run.sh scripts write to their own test directory's output/ folder.
AUDIO_OUTPUT_DIR=examples/asterisk/udp_hold_resume/output

# How long to hold the registration before unregistering and exiting.
IDLE_SECS=30

# How long registration/run.sh holds each smoke-test registration.
REGISTRATION_IDLE_SECS=2
