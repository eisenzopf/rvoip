# Remote Asterisk SIP server (defaults match the rvoip dev lab).
SIP_SERVER=192.168.1.103
SIP_PORT=5060
SIP_TRANSPORT=UDP

# Account (AOR + digest auth).
SIP_USERNAME=1001
SIP_AUTH_USERNAME=1001
SIP_PASSWORD=password123

# Local bind. 0.0.0.0 lets the OS pick the egress interface.
LOCAL_IP=0.0.0.0
LOCAL_PORT=5070

# How long to hold the registration before unregistering and exiting.
IDLE_SECS=30
