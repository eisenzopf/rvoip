# Remote Asterisk SIP server (defaults match the rvoip dev lab).
SIP_SERVER=192.168.1.103
SIP_PORT=5060
SIP_TRANSPORT=TLS

# Shared credentials. The lab Asterisk users 1001/1002 (TLS/SRTP) and
# 2001/2002 (UDP) all use this password unless auth usernames are overridden.
SIP_PASSWORD=password123

# Single-endpoint registration smoke test defaults to secure user 1001.
SIP_USERNAME=1001
SIP_AUTH_USERNAME=1001

# TLS registration and TLS/SRTP call examples.
SIP_TLS_PORT=5061
TLS_CA_PATH=/path/to/asterisk-ca.pem
TLS_INSECURE=0
ASTERISK_TLS_SRTP_REQUIRED=1

# Default TLS/SRTP mode for the Asterisk examples. Reachable contact mode
# registers over TLS and also listens on a TLS Contact port so Asterisk can
# open inbound TLS connections for INVITE, OPTIONS, BYE, re-INVITE, etc.
ASTERISK_TLS_CONTACT_MODE=reachable-contact

# Optional in reachable-contact mode. If left empty, run.sh generates a
# short-lived self-signed listener cert/key under the test output directory.
# Set these only when Asterisk verifies the endpoint listener certificate
# against a configured trust store.
TLS_CERT_PATH=
TLS_KEY_PATH=

# Optional mutual TLS client credentials. Leave unset for the normal
# outbound connection where Asterisk presents the server cert and the RVOIP
# endpoint only verifies it. Set these only if Asterisk requires client auth.
# TLS_CLIENT_CERT_PATH=/path/to/client.pem
# TLS_CLIENT_KEY_PATH=/path/to/client-key.pem

# Optional registered-flow modes. These do not require TLS_CERT_PATH or
# TLS_KEY_PATH because Asterisk must route inbound requests over the existing
# outbound TLS registration flow instead of opening a new connection to a
# listener Contact.
#   registered-flow-rfc5626   RFC 5626 Contact params: ;ob, +sip.instance, reg-id
#   registered-flow-symmetric Asterisk rewrite_contact/symmetric_transport style
# ASTERISK_TLS_CONTACT_MODE=registered-flow-rfc5626
# ASTERISK_TLS_CONTACT_MODE=registered-flow-symmetric
# Optional stable instance IDs for registered-flow modes. If unset, the
# examples derive deterministic per-user URNs from the endpoint username.
# ENDPOINT_1001_SIP_INSTANCE=urn:uuid:00000000-0000-4000-8000-000000001001
# ENDPOINT_1002_SIP_INSTANCE=urn:uuid:00000000-0000-4000-8000-000000001002

# Local bind and advertised addresses. LOCAL_IP is the socket bind address.
# If LOCAL_IP is 0.0.0.0, ADVERTISED_IP must be set so SIP Via sent-by and
# Contact do not advertise an unspecified address. MEDIA_ADVERTISED_IP
# controls SDP c=/o= media addresses and defaults to ADVERTISED_IP.
LOCAL_IP=0.0.0.0
ADVERTISED_IP=192.168.1.3
MEDIA_ADVERTISED_IP=192.168.1.3

# Single-endpoint registration smoke test SIP port.
LOCAL_PORT=5070

# Secure TLS/SRTP users. In reachable-contact mode, Contact advertises the TLS
# listener ports below:
#   sips:1001@ADVERTISED_IP:5071;transport=tls
#   sips:1002@ADVERTISED_IP:5073;transport=tls
ENDPOINT_1001_LOCAL_PORT=5070
ENDPOINT_1001_TLS_LOCAL_PORT=5071
ENDPOINT_1002_LOCAL_PORT=5072
ENDPOINT_1002_TLS_LOCAL_PORT=5073
ENDPOINT_1001_MEDIA_PORT_START=16000
ENDPOINT_1001_MEDIA_PORT_END=16100
ENDPOINT_1002_MEDIA_PORT_START=16120
ENDPOINT_1002_MEDIA_PORT_END=16220

# UDP/plain RTP users. The UDP scripts force SIP_TRANSPORT=UDP.
ENDPOINT_2001_LOCAL_PORT=5080
ENDPOINT_2002_LOCAL_PORT=5082
ENDPOINT_2001_MEDIA_PORT_START=17000
ENDPOINT_2001_MEDIA_PORT_END=17100
ENDPOINT_2002_MEDIA_PORT_START=17120
ENDPOINT_2002_MEDIA_PORT_END=17220

# Optional overrides when the Asterisk dialplan expects a different URI.
# ENDPOINT_1001_CALL_URI=sips:1002@192.168.1.103:5061
# ENDPOINT_2001_CALL_URI=sip:2002@192.168.1.103:5060

# Let both registered contacts sit briefly so Asterisk qualify OPTIONS probes
# can run before the caller places the test call.
POST_REGISTER_SETTLE_SECS=5

# Asterisk audio-path output when running endpoint binaries directly.
# The run.sh scripts write to their own test directory's output/ folder.
AUDIO_OUTPUT_DIR=examples/asterisk/udp_hold_resume/output

# How long to hold the registration before unregistering and exiting.
IDLE_SECS=30

# How long registration/run.sh holds each smoke-test registration.
REGISTRATION_IDLE_SECS=2

# Optional SRTP troubleshooting. This logs negotiated SDP media addresses,
# SRTP context installation, first inbound packet arrival, and decrypt/auth
# failure counts without logging SRTP keys or packet contents.
# RVOIP_SRTP_DIAGNOSTICS=1
