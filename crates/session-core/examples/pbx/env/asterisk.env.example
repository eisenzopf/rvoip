# Copy to env/asterisk.env or set these in your shell.
PBX_PROVIDER=asterisk
SIP_SERVER=192.168.1.103
SIP_PORT=5060
SIP_TLS_PORT=5061
SIP_PASSWORD=password123

LOCAL_IP=0.0.0.0
ADVERTISED_IP=192.168.1.3
MEDIA_ADVERTISED_IP=192.168.1.3

TLS_CA_PATH=/path/to/asterisk-ca.pem
TLS_INSECURE=0
ASTERISK_TLS_SRTP_REQUIRED=1
ASTERISK_TLS_CONTACT_MODE=reachable-contact

ENDPOINT_1001_LOCAL_PORT=5070
ENDPOINT_1001_TLS_LOCAL_PORT=5071
ENDPOINT_1002_LOCAL_PORT=5072
ENDPOINT_1002_TLS_LOCAL_PORT=5073
ENDPOINT_1003_LOCAL_PORT=5074
ENDPOINT_1003_TLS_LOCAL_PORT=5075

ENDPOINT_2001_LOCAL_PORT=5080
ENDPOINT_2002_LOCAL_PORT=5082
ENDPOINT_2003_LOCAL_PORT=5084

POST_REGISTER_SETTLE_SECS=5
REMOTE_TEST_TIMEOUT_SECS=60
REMOTE_TEST_DIGITS=1234#
ASTERISK_CALL_RETRY_ATTEMPTS=8
