# Copy to connect-probe.env and fill in. run-probe.sh sources this file.
# (connect-probe.env is gitignored — it holds credentials.)

# --- Amazon Connect (required) ---
export AMAZON_CONNECT_INSTANCE_ID=00000000-0000-0000-0000-000000000000
# The WebRTC/agent-routing contact flow the widget uses (so the screen pop is identical).
export AMAZON_CONNECT_FLOW_ID=00000000-0000-0000-0000-000000000000
export AWS_REGION=us-west-2

# --- AWS credentials (one of these) ---
# 1) Static keys with connect:StartWebRTCContact + connect:StopContact:
export AWS_ACCESS_KEY_ID=AKIA...
export AWS_SECRET_ACCESS_KEY=...
# export AWS_SESSION_TOKEN=...        # if using temporary creds
# 2) ...or a named profile:
# export AWS_PROFILE=connect-probe
# 3) ...or omit entirely on an EC2/ECS instance role.

# --- Optional ---
# Override the log filter (default streams chime_wire=trace):
# export RUST_LOG=info,rvoip_amazon_connect::chime_wire=trace
